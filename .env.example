# FinFlow Environment Configuration
# Copy this file to .env and populate values

# App Environment
APP_ENV=development
APP_VERSION=1.0.0

# Feature Flags (all false in offline/mock mode)
FEATURE_REAL_BANK_SYNC=false
FEATURE_EMAIL_INTELLIGENCE=false
FEATURE_PUSH_NOTIFICATIONS=false
FEATURE_ANALYTICS=false

# Mock Data Config
USE_MOCK_DATA=true
MOCK_DATA_SEED=finflow2026

# SQLite DB
LOCAL_DB_NAME=finflow_local.db
LOCAL_DB_VERSION=1

# Security
BIOMETRIC_TIMEOUT_MS=300000
SESSION_TIMEOUT_MS=900000
